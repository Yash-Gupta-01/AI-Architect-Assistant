# Optional explicit text model provider: openrouter, openai, or gemini
# Leave blank for automatic selection by available keys:
# OPENROUTER_API_KEY -> GEMINI_API_KEY -> OPENAI_API_KEY
AI_TEXT_PROVIDER=

# OpenRouter text model settings (default)
OPENROUTER_API_KEY=
OPENROUTER_TEXT_MODEL=openrouter/free


# Gemini text model settings
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.0-flash

# Optional explicit image provider: nvidia or google
# Leave blank for automatic selection by available keys:
# VERTEX_PROJECT_ID -> NVIDIA_API_KEY
IMAGE_PROVIDER=

# NVIDIA image model settings
NVIDIA_API_KEY=
NVIDIA_IMAGE_MODEL=black-forest-labs/flux.2-klein-4b

# Google Imagen image model settings (via Vertex AI)
# Authenticate via a service account JSON file or Application Default Credentials (gcloud auth).
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
GOOGLE_IMAGE_MODEL=imagen-4.0-generate-001
# Path to service account JSON key file (leave blank to use ADC / gcloud auth):
GOOGLE_APPLICATION_CREDENTIALS=

# Optional override for maximum plot area allowed by v1
NEXT_PUBLIC_MAX_PLOT_AREA_M2=500
